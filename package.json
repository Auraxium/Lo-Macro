{
  "name": "electrovite-react",
  "productName": "Lo-Macro",
  "version": "1.2.0",
  "description": "A simple Key Mapper and Macro ",
  "main": ".vite/build/main.js",
  "license": "MIT",
  "keywords": [
    "electrovite",
    "electron hot reload fast",
    "electron-boilerplate",
    "boilerplate",
    "electron-vite",
    "electron vitejs react",
    "vitejs with electron",
    "electron react boilerplate",
    "reactjs electronjs",
    "secure electron react app"
  ],
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint src tools --ext ts,tsx --max-warnings 0",
		"build": "electron-builder"
  },
  "config": {
    "forge": "./tools/forge/forge.config.js"
  },

	"build": {
		"appId": "com.Auraxium.Lo-Macro",
		"win": {
			"target": "NSIS"
		}
	},
  "devDependencies": {
    "@electron-forge/cli": "^6.2.1",
    "@electron-forge/maker-deb": "^6.2.1",
    "@electron-forge/maker-rpm": "^6.2.1",
    "@electron-forge/maker-squirrel": "^6.2.1",
    "@electron-forge/maker-zip": "^6.2.1",
    "@electron-forge/plugin-vite": "^6.2.1",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "@vitejs/plugin-react": "^4.0.2",
    "autoprefixer": "^10.4.16",
    "electron": "25.2.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.44.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "^8.4.31",
    "sass": "^1.63.6",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.1.6",
    "vite": "^4.4.0"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^2.0.0",
    "@futpib/node-global-key-listener": "^1.0.3",
    "@jitsi/robotjs": "^0.6.13",
    "@spacek33z/iohook": "^0.10.2",
    "@tabler/icons-react": "^2.38.0",
    "electron-squirrel-startup": "^1.0.0",
    "electron-vite": "^1.0.28",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0",
    "uiohook-napi": "^1.5.2"
  }
}
